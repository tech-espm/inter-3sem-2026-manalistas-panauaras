<div class="layout-root">
  <!-- Top Navigation Bar -->
  <header class="topbar">
    <div class="topbar-left">
      <div class="topbar-metric-icon">
        <span class="material-symbols-outlined topbar-logo-icon">
          health_metrics
        </span>
      </div>
      <h2 class="topbar-title">
        Módulo de Fluxo e Ocupação
      </h2>
    </div>
    <div class="topbar-right">
      <div class="system-status-chip">
        <span class="material-symbols-outlined system-status-dot">
          fiber_manual_record
        </span>
        <span class="system-status-text">
          Sistema Online
        </span>
      </div>
      <button class="icon-button icon-button-ghost-soft">
        <span class="material-symbols-outlined">
          notifications
        </span>
      </button>
      <button class="icon-button icon-button-ghost-soft">
        <span class="material-symbols-outlined">
          settings
        </span>
      </button>
      <div class="user-avatar user-avatar-small">
        <span class="material-symbols-outlined user-avatar-icon">
          person
        </span>
      </div>
    </div>
  </header>

  <div class="flex-layout">
    <!-- Sidebar -->
    <aside class="sidebar sidebar-thin">
      <div class="sidebar-unit-card">
        <p class="sidebar-unit-label">
          Unidade Selecionada
        </p>
        <p class="sidebar-unit-name">
          Hospital Central
        </p>
        <p class="sidebar-unit-meta">
          Prédio B - Ala Norte
        </p>
      </div>
      <nav class="sidebar-nav">
        <a href="#" class="sidebar-nav-item sidebar-nav-item-active">
          <span class="material-symbols-outlined">dashboard</span>
          Dashboard
        </a>
        <a href="#" class="sidebar-nav-item">
          <span class="material-symbols-outlined">analytics</span>
          Relatórios
        </a>
        <a href="#" class="sidebar-nav-item">
          <span class="material-symbols-outlined">sensors</span>
          Sensores PCA
        </a>
        <a href="#" class="sidebar-nav-item">
          <span class="material-symbols-outlined">history</span>
          Histórico
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="central-main central-main-padded">
      <!-- Header Section -->
      <section class="section-header">
        <div class="section-header-left">
          <h1 class="page-title">
            Monitoramento em Tempo Real
          </h1>
          <p class="page-location">
            <span class="material-symbols-outlined page-location-icon">
              location_on
            </span>
            Sala de Espera - Oncologia (Setor 04)
          </p>
        </div>
        <div class="section-header-right">
          <div class="last-update-card">
            <span class="last-update-label">
              Última Atualiz.
            </span>
            <span class="last-update-time">
              14:45:02
            </span>
          </div>
        </div>
      </section>

      <!-- Dashboard Grid -->
      <section class="dashboard-grid">
        <!-- Main Sector Card -->
        <article class="card occupancy-main-card">
          <div>
            <p class="occupancy-label">
              Pessoas no Setor
            </p>
            <div class="occupancy-count-row">
              <span class="occupancy-count" id="contagemOcupacao">
                --
              </span>
              <span class="occupancy-max" id="maximaOcupacao">
                / --
              </span>
            </div>
          </div>
          <div class="occupancy-meter">
            <div class="occupancy-meter-row">
              <span class="occupancy-meter-label">
                Nível de Ocupação
              </span>
              <span class="occupancy-meter-value" id="porcentagemOcupacao">
                --%
              </span>
            </div>
            <div class="occupancy-meter-bar">
              <div id="barraOcupacao" class="occupancy-meter-segment occupancy-meter-green" style="width: 0%"></div>
            </div>
            <p class="occupancy-warning">
              <span class="material-symbols-outlined occupancy-warning-icon">
                warning
              </span>
              Proporção crítica detectada
            </p>
          </div>
        </article>

        <!-- Real-time Graph (Last 60min) -->
        <article class="card occupancy-flow-card">
          <div class="card-header">
            <h3 class="graph-title">
              <span class="material-symbols-outlined graph-title-icon">
                timeline
              </span>
              Fluxo de Ocupação (60 min)
            </h3>
            <div class="graph-badges">
              <span class="graph-badge graph-badge-red">
                <span class="graph-badge-dot graph-badge-dot-red"></span>
                Crítico
              </span>
              <span class="graph-badge graph-badge-yellow">
                <span class="graph-badge-dot graph-badge-dot-yellow"></span>
                Alerta
              </span>
            </div>
          </div>
          <div class="flow-chart">
            <!-- bands -->
            <div class="flow-chart-bands">
              <div class="flow-band flow-band-critical"></div>
              <div class="flow-band flow-band-warning"></div>
              <div class="flow-band flow-band-normal"></div>
            </div>
            <!-- grid pattern is via CSS class -->
            <div class="flow-chart-inner chart-grid">
              <canvas id="fluxoOcupacaoChart" style="width: 100%; height: 100%;"></canvas>
            </div>
          </div>
          <div class="flow-chart-xlabels">
            <span>13:45</span>
            <span>14:00</span>
            <span>14:15</span>
            <span>14:30</span>
            <span>AGORA</span>
          </div>
        </article>

        <!-- Permanence Delta Graph -->
        <article class="card permanence-card">
          <div class="card-header">
            <h3 class="card-title-sm">
              Permanência em Pico
            </h3>
            <span class="material-symbols-outlined info-icon" title="Tempo médio de permanência durante alta ocupação">
              info
            </span>
          </div>
          <div class="permanence-bars">
            <div class="permanence-bar permanence-bar-soft h-40" title="Delta: 450s"></div>
            <div class="permanence-bar permanence-bar-mid h-60" title="Delta: 680s"></div>
            <div class="permanence-bar permanence-bar-strong h-85" title="Delta: 1120s"></div>
            <div class="permanence-bar permanence-bar-full h-95" title="Delta: 1240s"></div>
          </div>
          <div class="permanence-footer">
            <p class="permanence-caption">
              Média de estadia em lotação:
            </p>
            <p class="permanence-value">
              <span id="permanenciaTempo">--</span> <span class="permanence-unit">segundos</span>
            </p>
          </div>
        </article>

        <!-- Correlation Panel -->
        <article class="card correlation-card">
          <h3 class="card-title-sm mb-4">
            Correlação Ambiental
          </h3>
          <div class="correlation-wrapper">
            <div class="correlation-sync-line"></div>

            <div class="correlation-row">
              <div class="correlation-label">
                CO2 (ppm)
              </div>
              <div class="correlation-track">
                <canvas id="chartCO2" style="width: 100%; height: 30px;"></canvas>
              </div>
              <div class="correlation-value" id="valCO2">--</div>
            </div>

            <div class="correlation-row">
              <div class="correlation-label">
                Humid (%)
              </div>
              <div class="correlation-track">
                <canvas id="chartHumid" style="width: 100%; height: 30px;"></canvas>
              </div>
              <div class="correlation-value" id="valHumid">--</div>
            </div>

            <div class="correlation-row">
              <div class="correlation-label">
                Temp (°C)
              </div>
              <div class="correlation-track">
                <canvas id="chartTemp" style="width: 100%; height: 30px;"></canvas>
              </div>
              <div class="correlation-value" id="valTemp">--</div>
            </div>
          </div>
        </article>

        <!-- Action Suggestions -->
        <section class="actions-column">
          <article class="action-card-primary">
            <div class="action-card-header">
              <span class="material-symbols-outlined action-icon">
                auto_fix
              </span>
              <span class="action-label">
                Ações Sugeridas
              </span>
            </div>
            <p class="action-text">
              Lotação alta detectada.
              <span class="action-text-strong">
                Ativar ventilação forçada
              </span>
              em 10 min para controle de CO2.
            </p>
            <button class="action-button">
              Executar Agora
            </button>
          </article>

          <article class="action-card-secondary">
            <div class="action-secondary-header">
              <span class="material-symbols-outlined action-secondary-icon">
                cleaning_services
              </span>
              <span class="action-secondary-label">
                Manutenção
              </span>
            </div>
            <p class="action-secondary-text">
              Programar limpeza rápida após dispersão de fluxo
              (estimado 15:30).
            </p>
          </article>
        </section>
      </section>

      <!-- Detailed Table / Alerts -->
      <section class="card events-card">
        <div class="events-header">
          <h3 class="events-title">
            Eventos Recentes do Sensor PCA
          </h3>
          <button class="events-link">
            Ver todos
            <span class="material-symbols-outlined events-link-icon">
              chevron_right
            </span>
          </button>
        </div>
        <div class="table-wrapper">
          <table class="table table-compact">
            <thead class="events-table-head">
              <tr>
                <th>Horário</th>
                <th>Evento</th>
                <th>Ocupação</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="tabelaEventos">
              <tr><td colspan="4" class="text-center">Carregando eventos...</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

<%- contentFor("espaco-rodape") %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const chartSettingsMini = {
        type: 'line',
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false } },
            elements: { point: { radius: 0 } },
            layout: { padding: 0 }
        }
    };

    let chartCO2Instance = null;
    let chartHumidInstance = null;
    let chartTempInstance = null;
    let fluxoChartInstance = null;

    function renderMiniChart(canvasId, color, dataValues, chartRef) {
        const ctx = document.getElementById(canvasId).getContext('2d');
        if (chartRef) chartRef.destroy();
        return new Chart(ctx, {
            ...chartSettingsMini,
            data: {
                labels: dataValues.map((_, i) => i),
                datasets: [{ data: dataValues, borderColor: color, tension: 0.4, fill: false, borderWidth: 2 }]
            }
        });
    }

    async function carregarCorrelacaoAmbiental() {
       try {
           const resp = await fetch('/api/graficos/ambiental');
           const data = await resp.json();
           
           if(data.length > 0) {
               const latest = data[data.length - 1]; // O ultimo eh o atual
               document.getElementById('valCO2').innerText = latest.co2;
               document.getElementById('valHumid').innerText = latest.humid + '%';
               document.getElementById('valTemp').innerText = latest.temp;
               
               chartCO2Instance = renderMiniChart('chartCO2', '#10b981', data.map(d=>d.co2), chartCO2Instance);
               chartHumidInstance = renderMiniChart('chartHumid', '#3b82f6', data.map(d=>d.humid), chartHumidInstance);
               chartTempInstance = renderMiniChart('chartTemp', '#ef4444', data.map(d=>d.temp), chartTempInstance);

               // Altera o pseudo valor de permanencia apenas como mock interativo com base no dado
               document.getElementById('permanenciaTempo').innerText = (latest.co2 * 1.5).toFixed(0);
           }
       } catch (e) { console.error('Erro ao buscar correlacao:', e); }
    }

    async function carregarEventosRecentes() {
       try {
           const resp = await fetch('/api/sensores/eventos');
           const eventos = await resp.json();
           
           const tbody = document.getElementById('tabelaEventos');
           tbody.innerHTML = '';
           
           eventos.forEach(ev => {
               tbody.innerHTML += `<tr class="table-row">
                <td class="events-time">${ev.hora}</td>
                <td>${ev.evento}</td>
                <td>${ev.ocupacao}</td>
                <td><span class="badge ${ev.badge}">${ev.status}</span></td>
              </tr>`;
           });
       } catch (e) { console.error('Erro ao buscar eventos:', e); }
    }

    async function carregarOcupacao() {
      try {
        const resp = await fetch('/api/sensores/ocupacao');
        const data = await resp.json();

        document.getElementById('contagemOcupacao').innerText = data.pessoas_atuais;
        document.getElementById('maximaOcupacao').innerText = '/ ' + data.capacidade_maxima;
        document.getElementById('porcentagemOcupacao').innerText = data.porcentagem + '%';

        const barra = document.getElementById('barraOcupacao');
        barra.style.width = data.porcentagem + '%';

        // Troca a cor dependendo da porcentagem
        if (data.porcentagem > 80) barra.className = 'occupancy-meter-segment occupancy-meter-red';
        else if (data.porcentagem > 60) barra.className = 'occupancy-meter-segment occupancy-meter-yellow';
        else barra.className = 'occupancy-meter-segment occupancy-meter-green';

      } catch (err) { console.error('Erro ao buscar ocupação:', err); }
    }

    async function carregarGraficoFluxo() {
      try {
        const resp = await fetch('/api/graficos/ocupacao');
        const data = await resp.json();

        const labels = data.map(d => d.hora);
        const values = data.map(d => d.pessoas);

        const ctx = document.getElementById('fluxoOcupacaoChart').getContext('2d');
        if(fluxoChartInstance) fluxoChartInstance.destroy();

        fluxoChartInstance = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Pessoas',
              data: values,
              borderColor: '#3b82f6',
              tension: 0.4,
              fill: false
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { display: true },
              y: { beginAtZero: true }
            }
          }
        });

      } catch (err) { console.error('Erro ao desenhar grafico fluxo:', err); }
    }

    // Refresh general
    function reloadAllData() {
        carregarOcupacao();
        carregarGraficoFluxo();
        carregarCorrelacaoAmbiental();
        carregarEventosRecentes();
    }

    reloadAllData();
    setInterval(reloadAllData, 10000);
  </script>