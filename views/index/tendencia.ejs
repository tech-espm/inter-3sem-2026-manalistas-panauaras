              </div>

              <div class="graph-timeline" style="height:220px;position:relative">
                <canvas id="graficoMultiVariavel"></canvas>
              </div>
            </div>

            <!-- Scatter Plot -->
            <div class="card graph-card">
              <div class="graph-header">
                <div>
                  <h3 class="graph-title">
                    <span class="material-symbols-outlined graph-title-icon">
                      bubble_chart
                    </span>
                    CO2 vs Umidade
                  </h3>
                  <p class="graph-caption">
                    Cor: Range de VOC (Pobre a Ótimo)
                  </p>
