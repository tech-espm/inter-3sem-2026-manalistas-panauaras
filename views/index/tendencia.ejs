          </section>

          <!-- Compliance Table -->
          <section class="card compliance-card">
            <div class="compliance-header">
              <h3 class="compliance-title">
                <span class="material-symbols-outlined graph-title-icon">verified</span>
                Relatório de Conformidade Regulatória
              </h3>
              <div class="compliance-badges">
                <span id="complianceGlobalChip" class="compliance-chip">
                  <span class="material-symbols-outlined compliance-chip-icon">check_circle</span>
