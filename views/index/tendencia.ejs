                Correlação temporal e conformidade regulatória (ANVISA/ABNT)
              </p>
            </div>

            <div class="page-filters">
              <!-- Ambiente -->
              <div class="filter-field">
                <label class="filter-label">Ambiente</label>
                <select id="selectAmbiente" class="select-ambient">
                  <option value="">Todos os Ambientes</option>
                </select>
              </div>

              <!-- Período -->
              <div class="filter-field">
                <label class="filter-label">Período</label>
                <div class="period-toggle">
                  <button class="period-btn period-btn-active" data-periodo="24h">24h</button>
                  <button class="period-btn" data-periodo="7d">7d</button>
                  <button class="period-btn" data-periodo="30d">30d</button>
                </div>
              </div>

              <!-- Export -->
              <div class="filter-field filter-field-end">
                <button class="primary-action-button export-button">
                  <span class="material-symbols-outlined primary-action-icon">
                    picture_as_pdf
                  </span>
                  Gerar Relatório PDF
                </button>
              </div>
            </div>
          </section>

          <!-- KPI Quick Overview -->
          <section class="kpi-grid kpi-grid-equal mb-8">
            <div class="kpi-card kpi-card-soft">
              <div class="kpi-header kpi-header-tight">
                <span class="kpi-label">Média CO2</span>
                <span id="chipCO2" class="kpi-chip kpi-chip-down">
                  <span class="material-symbols-outlined kpi-chip-icon">trending_down</span>
                  <span id="chipCO2Texto">--%</span>
                </span>
              </div>
              <div class="kpi-value-row">
                <span id="kpiCO2" class="kpi-value">--</span>
                <span class="kpi-unit">ppm</span>
              </div>
            </div>

            <div class="kpi-card kpi-card-soft">
              <div class="kpi-header kpi-header-tight">
                <span class="kpi-label">Média VOC</span>
                <span id="chipVOC" class="kpi-chip kpi-chip-up-amber">
                  <span class="material-symbols-outlined kpi-chip-icon">trending_up</span>
                  <span id="chipVOCTexto">--%</span>
                </span>
              </div>
              <div class="kpi-value-row">
                <span id="kpiVOC" class="kpi-value">--</span>
                <span class="kpi-unit">ppb</span>
              </div>
            </div>

            <div class="kpi-card kpi-card-soft">
              <div class="kpi-header kpi-header-tight">
                <span class="kpi-label">Temperatura</span>
                <span id="chipTemp" class="kpi-chip kpi-chip-stable">
                  <span class="material-symbols-outlined kpi-chip-icon">horizontal_rule</span>
                  <span id="chipTempTexto">--%</span>
                </span>
              </div>
              <div class="kpi-value-row">
                <span id="kpiTemp" class="kpi-value">--</span>
                <span class="kpi-unit">°C</span>
              </div>
            </div>

            <div class="kpi-card kpi-card-soft">
              <div class="kpi-header kpi-header-tight">
                <span class="kpi-label">Umidade</span>
                <span id="chipUmidade" class="kpi-chip kpi-chip-down">
                  <span class="material-symbols-outlined kpi-chip-icon">trending_down</span>
                  <span id="chipUmidadeTexto">--%</span>
                </span>
              </div>
              <div class="kpi-value-row">
                <span id="kpiUmidade" class="kpi-value">--</span>
                <span class="kpi-unit">%</span>
              </div>
            </div>
          </section>

          <!-- Main Graphs Section -->
          <section class="graphs-grid mb-8">
            <!-- Temporal Correlation Graph -->
            <div class="card graph-card graph-card-wide">
              <div class="graph-header">
                <h3 class="graph-title">
                  <span class="material-symbols-outlined graph-title-icon">
                    timeline
                  </span>
                  Correlação Temporal Multi-Variável
                </h3>
                <div class="graph-legend">
                  <div class="graph-legend-item">
                    <span class="graph-dot graph-dot-primary"></span>
                    <span class="graph-legend-label">CO2</span>
                  </div>
                  <div class="graph-legend-item">
                    <span class="graph-dot graph-dot-emerald"></span>
                    <span class="graph-legend-label">Temp</span>
                  </div>
                  <div class="graph-legend-item">
                    <span class="graph-dot graph-dot-amber"></span>
                    <span class="graph-legend-label">VOC</span>
                  </div>
