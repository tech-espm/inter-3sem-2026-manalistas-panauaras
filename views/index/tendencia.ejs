            <div>
              <h2 class="topbar-title">HospitaLog AI</h2>
              <p class="topbar-subtitle">
                Monitoramento de Qualidade Ambiental
              </p>
            </div>
          </div>

          <div class="topbar-right">
            <button class="icon-button icon-button-soft-primary">
              <span class="material-symbols-outlined topbar-icon-md">
                notifications
              </span>
            </button>
            <button class="icon-button icon-button-soft-primary">
              <span class="material-symbols-outlined topbar-icon-md">
                settings
              </span>
            </button>
            <div class="topbar-divider"></div>
            <div class="topbar-user">
              <div class="user-meta">
