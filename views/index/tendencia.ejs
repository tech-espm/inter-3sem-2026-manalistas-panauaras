              </div>

              <div class="scatter-plot" style="height:180px;position:relative">
                <canvas id="graficoScatter"></canvas>
                <span class="scatter-x-label">Umidade (%)</span>
                <span class="scatter-y-label">CO2 (ppm)</span>
