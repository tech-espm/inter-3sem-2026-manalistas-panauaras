<%- contentFor('espaco-rodape') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  let graficoMulti = null;
  let graficoScatterChart = null;
  let periodoAtual = '24h';

  // Período buttons
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('period-btn-active'));
      btn.classList.add('period-btn-active');
      periodoAtual = btn.dataset.periodo;
      reloadTendencia();
    });
  });

  async function carregarSetores() {
    try {
      const setores = await (await fetch('/api/setores')).json();
      const sel = document.getElementById('selectAmbiente');
      setores.forEach(s => {
        const opt = document.createElement('option');
        opt.value = s.id_setor;
        opt.text = s.nome_setor;
        sel.appendChild(opt);
      });
    } catch(e) { console.error('Setores:', e); }
  }

  async function carregarResumo() {
    try {
      const r = await (await fetch('/api/sensores/resumo')).json();

      function setKPI(idValor, idChip, idChipTexto, valor, variacao, unidade) {
        document.getElementById(idValor).innerText = valor;
        const chip = document.getElementById(idChip);
        const vAbs = Math.abs(variacao);
        chip.className = `kpi-chip ${variacao < 0 ? 'kpi-chip-down' : (variacao > 0 ? 'kpi-chip-up-amber' : 'kpi-chip-stable')}`;
        const icon = chip.querySelector('.material-symbols-outlined');
        icon.innerText = variacao < 0 ? 'trending_down' : (variacao > 0 ? 'trending_up' : 'horizontal_rule');
        document.getElementById(idChipTexto).innerText = `${variacao > 0 ? '+' : ''}${variacao}%`;
      }

      setKPI('kpiCO2',     'chipCO2',     'chipCO2Texto',     r.co2_media,     r.co2_variacao_pct,     'ppm');
      setKPI('kpiVOC',     'chipVOC',     'chipVOCTexto',     r.voc_media,     r.voc_variacao_pct,     'ppb');
      setKPI('kpiTemp',    'chipTemp',    'chipTempTexto',    r.temp_media,    r.temp_variacao_pct,    '°C');
      setKPI('kpiUmidade', 'chipUmidade', 'chipUmidadeTexto', r.umidade_media, r.umidade_variacao_pct, '%');

      document.getElementById('auditTimestamp').innerText = r.hora_medicao;
    } catch(e) { console.error('Resumo:', e); }
  }

  async function carregarGraficos() {
    try {
      const dados = await (await fetch(`/api/graficos/ambiental?periodo=${periodoAtual}`)).json();
      const labels = dados.map(d => d.hora);

      // Gráfico multi-variável
      if (graficoMulti) graficoMulti.destroy();
      graficoMulti = new Chart(document.getElementById('graficoMultiVariavel'), {
        type: 'line',
        data: {
          labels,
          datasets: [
            { label: 'CO2 (ppm)', data: dados.map(d => d.co2),  borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.08)', tension: 0.4, fill: true },
            { label: 'Temp (°C)', data: dados.map(d => d.temp), borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.06)', tension: 0.4 },
            { label: 'VOC (ppb)', data: dados.map(d => d.voc),  borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.06)', tension: 0.4 },
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { position: 'top' } },
          scales: {
            x: { ticks: { maxTicksLimit: 10 } },
            y: { ticks: { maxTicksLimit: 6 } }
          }
        }
      });

      // Scatter plot CO2 vs Umidade colorido por VOC
      if (graficoScatterChart) graficoScatterChart.destroy();
      const maxVOC = Math.max(...dados.map(d => d.voc), 1);
      graficoScatterChart = new Chart(document.getElementById('graficoScatter'), {
        type: 'scatter',
        data: {
          datasets: [{
            label: 'CO2 vs Umidade',
            data: dados.map(d => ({ x: d.humid, y: d.co2 })),
            backgroundColor: dados.map(d => `hsl(${240 - (d.voc/maxVOC)*180}, 70%, 55%)`),
            pointRadius: 4,
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { title: { display: true, text: 'Umidade (%)' } },
            y: { title: { display: true, text: 'CO2 (ppm)' } }
          }
        }
      });
    } catch(e) { console.error('Gráficos:', e); }
  }

  async function carregarCompliance() {
    try {
      const { global, parametros } = await (await fetch(`/api/tendencia/compliance?periodo=${periodoAtual}`)).json();
      document.getElementById('complianceGlobalTexto').innerText = `${global}% COMPLIANCE GLOBAL`;

      const tbody = document.getElementById('complianceTbody');
      tbody.innerHTML = '';
      parametros.forEach(p => {
        const ok = p.pct_conformidade >= 95;
        const barClass = p.pct_conformidade >= 90 ? 'compliance-bar-fill-ok' : 'compliance-bar-fill-warn';
        const valClass = p.pct_conformidade >= 90 ? 'compliance-value-ok' : 'compliance-value-bad';
        const icon     = ok ? 'check_circle' : 'cancel';
        const iconClass= ok ? 'compliance-icon-ok' : 'compliance-icon-bad';
        tbody.insertAdjacentHTML('beforeend', `
          <tr class="table-row">
            <td class="table-cell-main">${p.parametro}</td>
            <td class="table-cell-sub">&lt; ${p.padrao_max} ${p.unidade}</td>
            <td>
              <div class="compliance-bar-row">
                <div class="compliance-bar-track">
                  <div class="compliance-bar-fill ${barClass}" style="width:${p.pct_conformidade}%"></div>
                </div>
                <span class="compliance-bar-text">${p.pct_conformidade}%</span>
              </div>
            </td>
            <td class="${valClass}">${p.desvio_max} ${p.unidade}</td>
            <td>Contínuo</td>
            <td class="table-cell-actions">
              <span class="material-symbols-outlined ${iconClass}">${icon}</span>
            </td>
          </tr>
        `);
      });
    } catch(e) { console.error('Compliance:', e); }
  }

  function reloadTendencia() {
    carregarResumo();
    carregarGraficos();
    carregarCompliance();
  }

  carregarSetores();
  reloadTendencia();
  setInterval(reloadTendencia, 30000);
</script>
