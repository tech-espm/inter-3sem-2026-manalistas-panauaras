<div class="page-container">
  <!-- Sidebar Filters -->
  <aside class="sidebar">
    <!-- Global Indicator Card -->
    <div class="card card-center">
      <h3 class="card-subtitle">Índice Ambiental</h3>
      <div class="gauge-container">
        <svg>
          <circle cx="64" cy="64" r="56" fill="transparent" stroke="currentColor" stroke-width="8" class="gauge-track">
          </circle>
          <circle class="gauge-ring" cx="64" cy="64" r="56" fill="transparent" stroke="currentColor" stroke-width="8"
            stroke-dasharray="351.85" stroke-dashoffset="70.37" stroke-linecap="round"></circle>
        </svg>
        <div class="gauge-center">
          <span class="gauge-value">80</span>
          <span class="gauge-label">Score</span>
        </div>
      </div>
      <div class="status-pill status-pill-success">
        <span class="material-symbols-outlined status-pill-icon">
          check_circle
        </span>
        <span class="status-pill-text">ESTÁVEL</span>
      </div>
    </div>

    <!-- Filtros -->
    <div class="card filter-card">
      <h3 class="card-title">Filtros de Setor</h3>
      <div class="filter-list">
        <label class="filter-item">
          <input type="checkbox" checked class="checkbox-base" />
          <span>UTIs</span>
        </label>
        <label class="filter-item">
          <input type="checkbox" checked class="checkbox-base" />
          <span>Enfermarias</span>
        </label>
        <label class="filter-item">
          <input type="checkbox" checked class="checkbox-base" />
          <span>Sanitários</span>
        </label>
        <label class="filter-item">
          <input type="checkbox" checked class="checkbox-base" />
          <span>Salas de Espera</span>
        </label>
      </div>

      <hr class="card-divider" />

      <h3 class="card-title">Tipos de Risco</h3>
      <div class="chip-group">
        <button class="chip chip-active">Ventilação</button>
        <button class="chip">Sanitário</button>
        <button class="chip">Conforto</button>
      </div>

      <hr class="card-divider" />

      <div class="toggle-wrapper">
        <span class="toggle-label">Apenas Alertas</span>
        <label class="toggle-label-wrapper">
          <input class="toggle-input" type="checkbox" />
          <div class="toggle"></div>
        </label>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <!-- Highlight Cards -->
    <section class="highlight-grid">
      <div class="highlight-card highlight-card-danger">
        <div class="highlight-icon highlight-icon-danger">
          <span class="material-symbols-outlined">co2</span>
        </div>
        <div>
          <p class="highlight-label">Maior CO2</p>
          <h4 class="highlight-title">UTI Adulto 2</h4>
          <p class="highlight-meta highlight-meta-danger">
            1240 ppm (+15%)
          </p>
        </div>
      </div>

      <div class="highlight-card highlight-card-warning">
        <div class="highlight-icon highlight-icon-warning">
          <span class="material-symbols-outlined">air</span>
        </div>
        <div>
          <p class="highlight-label">Maior VOC</p>
          <h4 class="highlight-title">Enfermaria Ala B</h4>
          <p class="highlight-meta highlight-meta-warning">Médio Risco</p>
        </div>
      </div>

      <div class="highlight-card highlight-card-primary">
        <div class="highlight-icon highlight-icon-primary">
          <span class="material-symbols-outlined">clean_hands</span>
        </div>
        <div>
          <p class="highlight-label">Eventos de Odor (Hoje)</p>
          <h4 class="highlight-title">Sanitário P3</h4>
          <p class="highlight-meta highlight-meta-primary">
            12 ocorrências
          </p>
        </div>
      </div>
    </section>

    <!-- Heatmap Grid -->
    <section class="card heatmap-card">
      <div class="heatmap-header">
        <h3 class="heatmap-title">Mapa Térmico de Riscos</h3>
        <div class="heatmap-legend">
          <div class="legend-item">
            <span class="legend-dot legend-dot-green"></span>
            <span>Normal</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot-yellow"></span>
            <span>Tendência Alerta</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot-red"></span>
            <span>Crítico</span>
          </div>
        </div>
      </div>

      <div class="heatmap-grid">
        <!-- Block 1: UTI 01 -->
        <!-- Block 1: UTI 01 (Crítico) -->
        <article class="heat-tile heat-tile-critical">
          <div class="heat-tile-header">
            <div class="tile-info">
              <h4 class="heat-tile-title">UTI 01</h4>
              <p class="heat-tile-badge heat-tile-badge-critical">Crítico</p>
            </div>

            <!-- Nova Bolinha Interativa -->
            <div class="status-indicator">
              <span class="status-dot-pulse dot-danger"></span>
              <div class="status-tooltip">
                <strong>4 ALERTAS</strong> (24h)
              </div>
            </div>
          </div>

          <div class="sparkline">
            <div class="spark-bar spark-red-40 h-40"></div>
            <div class="spark-bar spark-red-40 h-60"></div>
            <div class="spark-bar spark-red-40 h-100"></div>
          </div>
          <p class="heat-tile-metric">CO2: <span class="metric-danger">1450 ppm</span></p>
        </article>

        <!-- Block 2: Ala B (Normal) -->
        <article class="heat-tile heat-tile-normal">
          <div class="heat-tile-header">
            <div class="tile-info">
              <h4 class="heat-tile-title">Ala B - Leitos</h4>
              <p class="heat-tile-badge heat-tile-badge-normal">Normal</p>
            </div>

            <div class="status-indicator">
              <span class="status-dot-pulse dot-success"></span>
              <div class="status-tooltip">Sistema Estável</div>
            </div>
          </div>

          <div class="sparkline">
            <div class="spark-bar spark-green-30 h-20"></div>
            <div class="spark-bar spark-green-40 h-25"></div>
          </div>
          <p class="heat-tile-metric">CO2: <span class="metric-success">420 ppm</span></p>
        </article>

        <!-- Block 3: Espera Principal (Atenção) -->
        <article class="heat-tile heat-tile-warning">
          <div class="heat-tile-header">
            <div class="tile-info">
              <h4 class="heat-tile-title">Espera Principal</h4>
              <p class="heat-tile-badge heat-tile-badge-warning">Atenção</p>
            </div>

            <div class="status-indicator">
              <span class="status-dot-pulse dot-warning"></span>
              <div class="status-tooltip"><strong>1 ALERTA</strong> pendente</div>
            </div>
          </div>

          <div class="sparkline">
            <div class="spark-bar spark-yellow-30 h-50"></div>
            <div class="spark-bar spark-yellow-40 h-60"></div>
          </div>
          <p class="heat-tile-metric">CO2: <span class="metric-warning">880 ppm</span></p>
        </article>

      </div>
    </section>

    <!-- Footer / Status Bar -->
    <footer class="statusbar">
      <div class="statusbar-left">
        <div class="status-item">
          <span class="material-symbols-outlined status-item-icon sync-icon">
            sync
          </span>
          <span class="status-item-text">
            Última atualização: agora mesmo
          </span>
        </div>
        <div class="status-item">
          <span class="material-symbols-outlined status-item-icon sensors-icon">
            sensors
          </span>
          <span class="status-item-text">142 Sensores Ativos</span>
        </div>
      </div>

      <div class="statusbar-right">
        <button class="link-button-primary">
          <span class="material-symbols-outlined link-button-icon">
            download
          </span>
          Exportar Relatório Mensal
        </button>
        <div class="vertical-divider"></div>
        <button class="link-button-muted">Sistema v2.4.1</button>
      </div>
    </footer>
  </main>
</div>